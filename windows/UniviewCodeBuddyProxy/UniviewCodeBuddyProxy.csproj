<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>UniviewCodeBuddyProxy</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinUI 3 / Windows App SDK -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.5.250108004" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core proxy library (contains ASP.NET Core server code) -->
    <ProjectReference Include="..\UniviewCodeBuddyProxy.Core\UniviewCodeBuddyProxy.Core.csproj">
      <PrivateAssets>all</PrivateAssets>
      <!-- Prevent FrameworkReference from flowing transitively -->
      <ExcludeAssets>build</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>

  <!-- Suppress transitive FrameworkReference from Core library — ASP.NET Core assemblies
       must NOT reach XamlCompiler (a .NET Framework 4.7.2 process that crashes with 200+ extra refs) -->
  <ItemGroup>
    <FrameworkReference Remove="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Also remove any ASP.NET Core reference assemblies that snuck through -->
  <Target Name="RemoveAspNetCoreRefsBeforeXaml" BeforeTargets="XamlMarkupCompilePass1">
    <ItemGroup>
      <ReferencePath Remove="@(ReferencePath)" Condition="$([System.String]::new('%(FullPath)').Contains('Microsoft.AspNetCore'))" />
      <Reference Remove="@(Reference)" Condition="$([System.String]::new('%(Identity)').Contains('Microsoft.AspNetCore'))" />
    </ItemGroup>
    <Message Importance="high" Text="Removed ASP.NET Core reference assemblies before XamlCompiler. Remaining: @(ReferencePath->Count())" />
  </Target>

  <ItemGroup>
    <!-- App manifest for unpackaged deployment -->
    <Content Include="app.manifest" />
  </ItemGroup>
</Project>
