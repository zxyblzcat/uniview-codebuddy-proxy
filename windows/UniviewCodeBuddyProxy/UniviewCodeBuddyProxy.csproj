<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>UniviewCodeBuddyProxy</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
    <!-- Use in-process CompileXaml task even with dotnet build (MSBuildRuntimeType=Core).
         The default (UseXamlCompilerExecutable=true) launches the net472 XamlCompiler.exe
         out-of-process, which crashes when loading .NET 6/8 reference assemblies.
         The net6.0 in-process task handles .NET 8 refs correctly. -->
    <UseXamlCompilerExecutable>false</UseXamlCompilerExecutable>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinUI 3 / Windows App SDK -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.7.260224002" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core proxy library — normal project reference.
         ASP.NET Core FrameworkReference from Core is excluded via Directory.Build.targets
         before XamlCompiler runs, preventing the .NET Framework 4.7.2 XamlCompiler.exe
         from crashing on .NET 6/8 reference assemblies. -->
    <ProjectReference Include="..\UniviewCodeBuddyProxy.Core\UniviewCodeBuddyProxy.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- App manifest for unpackaged deployment -->
    <Content Include="app.manifest" />
  </ItemGroup>
</Project>
