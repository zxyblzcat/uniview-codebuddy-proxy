<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>UniviewCodeBuddyProxy</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinUI 3 / Windows App SDK -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.7.260224002" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
  </ItemGroup>

  <!--
    Explicitly add WinRT.Runtime.dll and the CsWinRT source generator from the
    SDK.NET.Ref NuGet package. The FrameworkReference targeting pack only adds
    Microsoft.Windows.SDK.NET.dll to compile references; without WinRT.Runtime.dll
    and the source generator, CsWinRT projected types like Microsoft.UI.Color
    cannot be resolved. These are added at project evaluation time (not in a target)
    so the source generator is available when CoreCompile runs.
  -->
  <ItemGroup>
    <Reference Include="WinRT.Runtime">
      <HintPath>$(NuGetPackageRoot)microsoft.windows.sdk.net.ref\10.0.19041.56\lib\net8.0\WinRT.Runtime.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Analyzer Include="$(NuGetPackageRoot)microsoft.windows.sdk.net.ref\10.0.19041.56\analyzers\dotnet\cs\WinRT.SourceGenerator.dll" />
  </ItemGroup>

  <!--
    Add CsWinRTInputs for the versioned .winmd files from the WindowsAppSDK NuGet package.
    Microsoft.WinUI.References.targets only adds lib/uap10.0/*.winmd to CsWinRTInputs,
    but Microsoft.UI.winmd (defining Microsoft.UI.Color, Microsoft.UI.Colors, etc.),
    Microsoft.Foundation.winmd, and Microsoft.Graphics.winmd are only in the versioned
    subdirectory (uap10.0.17763). Without these, the CsWinRT source generator does not
    produce the projected types, causing CS0246 on CI where the full VS MSBuild setup
    is absent.
  -->
  <ItemGroup>
    <CsWinRTInputs Include="$(NuGetPackageRoot)microsoft.windowsappsdk\1.7.260224002\lib\uap10.0.17763\Microsoft.UI.winmd" />
    <CsWinRTInputs Include="$(NuGetPackageRoot)microsoft.windowsappsdk\1.7.260224002\lib\uap10.0.17763\Microsoft.Foundation.winmd" />
    <CsWinRTInputs Include="$(NuGetPackageRoot)microsoft.windowsappsdk\1.7.260224002\lib\uap10.0.17763\Microsoft.Graphics.winmd" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core proxy library — normal project reference.
         ASP.NET Core FrameworkReference from Core is excluded via Directory.Build.targets
         before XamlCompiler runs, preventing the .NET Framework 4.7.2 XamlCompiler.exe
         from crashing on .NET 6/8 reference assemblies. -->
    <ProjectReference Include="..\UniviewCodeBuddyProxy.Core\UniviewCodeBuddyProxy.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- App manifest for unpackaged deployment -->
    <Content Include="app.manifest" />
  </ItemGroup>
</Project>
