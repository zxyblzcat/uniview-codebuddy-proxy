<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>UniviewCodeBuddyProxy</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
  </PropertyGroup>

  <ItemGroup>
    <!-- WinUI 3 / Windows App SDK -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.5.250108004" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core proxy library — referenced as a direct assembly reference instead of ProjectReference
         to prevent transitive FrameworkReference (Microsoft.AspNetCore.App) from flowing into
         XamlCompiler's input.json and crashing the .NET Framework 4.7.2 process.
         The C# compiler can still resolve types from Core, but XamlCompiler won't try to load
         its ASP.NET Core dependencies.
    -->
    <ProjectReference Include="..\UniviewCodeBuddyProxy.Core\UniviewCodeBuddyProxy.Core.csproj">
      <PrivateAssets>all</PrivateAssets>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <!-- After Core builds, add its output as a direct Reference (no transitive deps) -->
  <Target Name="_AddCoreDllReference" AfterTargets="ResolveProjectReferences" DependsOnTargets="ResolveProjectReferences">
    <PropertyGroup>
      <_CoreDllPath>..\UniviewCodeBuddyProxy.Core\bin\$(Platform)\$(Configuration)\net8.0\UniviewCodeBuddyProxy.Core.dll</_CoreDllPath>
    </PropertyGroup>
    <ItemGroup>
      <Reference Include="$(_CoreDllPath)">
        <Private>true</Private>
        <HintPath>$(_CoreDllPath)</HintPath>
      </Reference>
    </ItemGroup>
    <Message Importance="high" Text="[_AddCoreDllReference] Added Core DLL reference: $(_CoreDllPath)" />
  </Target>

  <ItemGroup>
    <!-- App manifest for unpackaged deployment -->
    <Content Include="app.manifest" />
  </ItemGroup>
</Project>
