<UserControl
    x:Class="UniviewCodeBuddyProxy.Controls.GlassCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="HoverStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                        <Setter Target="CardBorder.BorderBrush" Value="{ThemeResource ControlStrokeColorOnAccentDefaultBrush}"/>
                        <Setter Target="CardBorder.Translation" Value="0,-2,0"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Card background with acrylic -->
        <Border x:Name="CardBorder"
                Grid.RowSpan="3"
                CornerRadius="20"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                Padding="0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
        </Border>

        <!-- Top highlight line -->
        <Rectangle Grid.RowSpan="3"
                   Height="1"
                   Margin="20,0"
                   VerticalAlignment="Top"
                   RadiusX="0.5" RadiusY="0.5"
                   x:Name="HighlightLine">
            <Rectangle.Fill>
                <LinearGradientBrush x:Name="HighlightGradient" StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop x:Name="HighlightStart" Color="#1AFFFFFF" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Header row (optional) -->
        <StackPanel x:Name="HeaderPanel"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="20,20,20,0"
                    Visibility="Collapsed">
            <FontIcon x:Name="HeaderIcon"
                      Glyph=""
                      FontSize="14"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            <TextBlock x:Name="HeaderText"
                       Text=""
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Header divider -->
        <Border x:Name="HeaderDivider"
                Grid.Row="1"
                Margin="20,12,20,0"
                Height="1"
                Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                Visibility="Collapsed"/>

        <!-- Content presenter -->
        <ContentPresenter Grid.Row="2"
                          Margin="20"/>
    </Grid>
</UserControl>
