<Window
    x:Class="UniviewCodeBuddyProxy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:UniviewCodeBuddyProxy.Controls"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Background Gradient Layers ═══ -->

        <!-- Layer 1: Base fill -->
        <Border Grid.RowSpan="2" x:Name="BgLayer1" IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush x:Name="BgBaseBrush" Color="#0B0F19" />
            </Border.Background>
        </Border>

        <!-- Layer 2: Center primary glow -->
        <Border Grid.RowSpan="2" x:Name="BgLayer2" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush x:Name="BgPrimaryGlow"
                                     Center="0.5,0.5"
                                     RadiusX="0.6" RadiusY="0.6"
                                     MappingMode="RelativeToBoundingBox"
                                     SpreadMethod="Pad">
                    <GradientStop x:Name="PrimaryGlowStop" Color="#145B9CF6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Layer 3: Top-right accent glow -->
        <Border Grid.RowSpan="2" x:Name="BgLayer3" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush x:Name="BgAccentGlow"
                                     Center="0.85,0.15"
                                     RadiusX="0.45" RadiusY="0.45"
                                     MappingMode="RelativeToBoundingBox"
                                     SpreadMethod="Pad">
                    <GradientStop x:Name="AccentGlowStop" Color="#0D34D4AA" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Layer 4: Bottom-left depth glow -->
        <Border Grid.RowSpan="2" x:Name="BgLayer4" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush x:Name="BgDepthGlow"
                                     Center="0.1,0.9"
                                     RadiusX="0.4" RadiusY="0.4"
                                     MappingMode="RelativeToBoundingBox"
                                     SpreadMethod="Pad">
                    <GradientStop x:Name="DepthGlowStop" Color="#0A5B9CF6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══ Top Status Bar ═══ -->
        <Border
            x:Name="StatusBar"
            Grid.Row="0"
            Padding="16,8"
            Background="{x:Bind ThemeManager.Colors.SurfaceBrush, Mode=OneWay}"
            BorderBrush="{x:Bind ThemeManager.Colors.GlassBorderBrush, Mode=OneWay}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Connection indicator -->
                <Ellipse
                    x:Name="ConnectionIndicator"
                    Grid.Column="0"
                    Width="8"
                    Height="8"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Fill="{ThemeResource SystemFillColorSuccessBrush}" />

                <!-- Proxy status -->
                <TextBlock
                    x:Name="ProxyStatusText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{x:Bind ThemeManager.Colors.TextBrush, Mode=OneWay}"
                    Text="代理运行中" />

                <!-- Separator -->
                <TextBlock
                    Grid.Column="2"
                    Margin="12,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{x:Bind ThemeManager.Colors.TextMutedBrush, Mode=OneWay}"
                    Text="|" />

                <!-- Model count -->
                <TextBlock
                    x:Name="ModelCountText"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{x:Bind ThemeManager.Colors.TextSecondaryBrush, Mode=OneWay}"
                    Text="0 个模型可用" />

                <!-- Current status label -->
                <TextBlock
                    x:Name="StatusText"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{x:Bind ThemeManager.Colors.TextSecondaryBrush, Mode=OneWay}"
                    Text="仪表盘" />
            </Grid>
        </Border>

        <!-- ═══ Content Area with Glass Background ═══ -->
        <Grid x:Name="ContentArea" Grid.Row="1">
            <NavigationView
                x:Name="NavView"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="NavigationPaneLeft"
                SelectionChanged="NavView_SelectionChanged"
                OpenPaneLength="200"
                Background="Transparent">

                <NavigationView.MenuItems>
                    <NavigationViewItem
                        Content="仪表盘"
                        Tag="Dashboard"
                        IsSelected="True">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem
                        Content="模型管理"
                        Tag="Models">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE912;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem
                        Content="令牌管理"
                        Tag="Tokens">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE72E;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem
                        Content="日志"
                        Tag="Logs">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE8BD;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>

                <NavigationView.FooterMenuItems>
                    <NavigationViewItem
                        Content="设置"
                        Tag="Settings">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.FooterMenuItems>

                <!-- Page content frame -->
                <Frame
                    x:Name="ContentFrame"
                    Background="Transparent"
                    IsNavigationStackEnabled="True"
                    NavigationFailed="OnNavigationFailed">
                    <Frame.ContentTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </Frame.ContentTransitions>
                </Frame>
            </NavigationView>
        </Grid>

        <!-- Toast overlay -->
        <controls:Toast
            x:Name="AppToast"
            Grid.Row="0"
            Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,16,0,0"
            Visibility="Collapsed" />
    </Grid>
</Window>
