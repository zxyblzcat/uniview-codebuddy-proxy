<Application
    x:Class="UniviewCodeBuddyProxy.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UniviewCodeBuddyProxy">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Toast shadow — OffsetY set in App.xaml.cs because XamlCompiler doesn't support ThemeShadow.OffsetY in XAML -->
            <ThemeShadow x:Key="ToastShadow" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
