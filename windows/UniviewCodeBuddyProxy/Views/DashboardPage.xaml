<Page
    x:Class="UniviewCodeBuddyProxy.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:UniviewCodeBuddyProxy.Controls"
    mc:Ignorable="d">

    <ScrollView>
        <StackPanel Spacing="20" Margin="24">

            <!-- KPI Cards Row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Active Tokens -->
                <controls:KPICard Grid.Column="0"
                    Title="活跃令牌"
                    Value="{x:Bind ViewModel.ActiveTokens, Mode=OneWay}"
                    AccentColor="{ThemeResource SystemFillColorSuccessBrush}"/>

                <!-- Requests Today -->
                <controls:KPICard Grid.Column="1"
                    Title="今日请求"
                    Value="{x:Bind ViewModel.RequestsToday, Mode=OneWay}"
                    AccentColor="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                <!-- Avg Latency -->
                <controls:KPICard Grid.Column="2"
                    Title="平均延迟"
                    Value="{x:Bind ViewModel.AvgLatency, Mode=OneWay}"
                    AccentColor="{ThemeResource SystemFillColorCautionBrush}"/>

                <!-- Uptime -->
                <controls:KPICard Grid.Column="3"
                    Title="运行时间"
                    Value="{x:Bind ViewModel.Uptime, Mode=OneWay}"
                    AccentColor="{ThemeResource SystemFillColorSuccessBrush}"/>
            </Grid>

            <!-- Charts Row -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart -->
                <controls:GlassCard Grid.Column="0" Header="每小时请求">
                    <controls:BarChart x:Name="BarChartControl" Height="180" />
                </controls:GlassCard>

                <!-- Donut Chart -->
                <controls:GlassCard Grid.Column="1" Header="模型使用">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Donut circle -->
                        <controls:DonutChart x:Name="DonutChartControl" Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Legend -->
                        <ListView Grid.Column="1"
                                  ItemsSource="{x:Bind ViewModel.ModelUsage, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="6" Padding="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding ColorBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="Medium"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                            <Run Text="{Binding PercentDisplay}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </controls:GlassCard>
            </Grid>

            <!-- Recent Activity -->
            <controls:GlassCard Header="近期活动">
                <ListView x:Name="ActivityList"
                          ItemsSource="{x:Bind ViewModel.RecentActivity, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          MaxHeight="200">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding LevelEmoji}" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="{Binding ShortTime}" FontSize="11"
                                           FontFamily="Cascadia Code"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </controls:GlassCard>

        </StackPanel>
    </ScrollView>
</Page>
