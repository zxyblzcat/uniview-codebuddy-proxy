<Page
    x:Class="UniviewCodeBuddyProxy.Views.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:UniviewCodeBuddyProxy.Controls"
    mc:Ignorable="d">

    <Grid RowSpacing="16" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="0"
                        PlaceholderText="搜索模型..."
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                        QueryIcon="Find"
                        CornerRadius="8"/>

        <!-- Provider filter chips -->
        <ScrollView Grid.Row="1" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Providers, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <RadioButton x:Name="ProviderChip"
                                         Content="{Binding}"
                                         GroupName="ProviderFilter"
                                         Checked="OnProviderChipChecked"
                                         CornerRadius="12"
                                         Padding="12,6"
                                         FontSize="12"
                                         MinWidth="0"/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollView>

        <!-- Models grid -->
        <GridView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.FilteredModels, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="OnModelClick"
                  Padding="0">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <controls:GlassCard CardCornerRadius="12">
                        <StackPanel Spacing="6" MinWidth="180">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding OwnedBy}"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </controls:GlassCard>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</Page>
