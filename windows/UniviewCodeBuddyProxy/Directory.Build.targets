<Project>
  <!--
    Remove XamlPreCompile from PrepareResourcesDependsOn.
    XamlPreCompile runs the net472 XamlCompiler.exe which cannot resolve .NET 8
    reference assemblies, causing compilation errors. By removing it, C# compilation
    is deferred to CoreCompile which uses the correct .NET 8 SDK Roslyn compiler.

    We also override XamlPreCompile and MarkupCompilePass2 as no-op targets to
    ensure the net472 XamlCompiler.exe is never invoked. MarkupCompilePass2 also
    calls XamlCompiler.exe, which fails on CI.

    The Color/Colors polyfill (Helpers/WinUIColorPolyfill.cs) ensures that
    Microsoft.UI.Color and Microsoft.UI.Colors are available to CoreCompile even
    when the CsWinRT source generator doesn't run (CI environments).

    Note: Skipping MarkupCompilePass2 means x:Bind won't be compiled. If x:Bind
    is needed, the build must be done in Visual Studio locally.
  -->
  <PropertyGroup>
    <PrepareResourcesDependsOn>
      MarkupCompilePass1;
      $(PrepareResourcesDependsOn)
    </PrepareResourcesDependsOn>
  </PropertyGroup>

  <!--
    Override XamlPreCompile and MarkupCompilePass2 as no-ops so the net472
    XamlCompiler.exe is never invoked. These targets are defined in
    Microsoft.UI.Xaml.Markup.Compiler.interop.targets and run XamlCompiler.exe.
  -->
  <Target Name="XamlPreCompile" />
  <Target Name="MarkupCompilePass2" />

  <!--
    Skip PRI (Package Resource Index) generation on CI.
    The ExpandPriContent task requires Microsoft.Build.Packaging.Pri.Tasks.dll
    which is only available with the Visual Studio workload, not on CI runners.
    For unpackaged apps (WindowsPackageType=None), PRI generation is not needed.
  -->
  <PropertyGroup>
    <AppxPackage>false</AppxPackage>
    <GeneratePri>false</GeneratePri>
    <EnableMrtTargets>false</EnableMrtTargets>
    <DisableMrtAutoMerger>true</DisableMrtAutoMerger>
  </PropertyGroup>

  <!--
    Override the _ExpandPriContent target (from MrtCore.PriGen.targets) as a no-op
    so ExpandPriContent task is never invoked. That task requires
    Microsoft.Build.Packaging.Pri.Tasks.dll which is only available with the
    Visual Studio MSBuild workload, not on GitHub Actions runners.
  -->
  <Target Name="_ExpandPriContent" />

  <!--
    Set LocalAssembly before MarkupCompilePass2 so x:Bind type resolution works.
    WMC1509 "No LocalAssembly parameter given during MarkupCompilePass2" occurs when
    the intermediate assembly doesn't exist yet on first build.
  -->
  <Target Name="_SetLocalAssemblyForMarkupCompilePass2"
          BeforeTargets="MarkupCompilePass2"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences;CoreCompile">
    <PropertyGroup>
      <LocalAssembly Condition="'$(LocalAssembly)' == ''">$(IntermediateOutputPath)$(TargetName)$(TargetExt)</LocalAssembly>
      <XamlLocalAssembly Condition="'$(XamlLocalAssembly)' == ''">$(LocalAssembly)</XamlLocalAssembly>
    </PropertyGroup>
    <Message Importance="high" Text="[_SetLocalAssemblyForMarkupCompilePass2] LocalAssembly=$(LocalAssembly)" />
  </Target>
</Project>
