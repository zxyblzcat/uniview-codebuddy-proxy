<Project>
  <!--
    Remove XamlPreCompile from PrepareResourcesDependsOn.
    XamlPreCompile runs an in-process C# compilation via the net472 XamlCompiler.exe
    which cannot resolve CsWinRT projected types (Microsoft.UI.Color etc.), causing
    CS0246. By removing it, C# compilation is deferred to CoreCompile which uses the
    correct .NET 8 SDK Roslyn + CsWinRT source generator for WinRT type projection.
  -->
  <PropertyGroup>
    <PrepareResourcesDependsOn>
      MarkupCompilePass1;
      MarkupCompilePass2;
      $(PrepareResourcesDependsOn)
    </PrepareResourcesDependsOn>
  </PropertyGroup>

  <!--
    Add WinRT.Runtime.dll and WinRT.SourceGenerator.dll explicitly.

    The Microsoft.Windows.SDK.NET.Ref NuGet package contains these alongside
    Microsoft.Windows.SDK.NET.dll, but the .NET SDK's FrameworkReference targeting
    pack resolution only includes Microsoft.Windows.SDK.NET.dll in the compile
    reference list. Without WinRT.Runtime.dll AND the CsWinRT source generator,
    the compiler cannot resolve projected types like Microsoft.UI.Color.

    We locate these DLLs by finding Microsoft.Windows.SDK.NET.dll in the reference
    paths and deriving the companion DLL paths from its directory.
  -->
  <Target Name="_AddCsWinRTReferences"
          BeforeTargets="CoreCompile"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences">
    <ItemGroup>
      <_SdkNetRefCandidate Include="@(ReferencePath)" Condition="$([System.String]::new('%(FileName)').Equals('Microsoft.Windows.SDK.NET')) And $([System.String]::new('%(Extension)').Equals('.dll'))" />
    </ItemGroup>
    <PropertyGroup>
      <!-- Derive paths from the SDK.NET.Ref package directory (same parent as Microsoft.Windows.SDK.NET.dll) -->
      <_SdkNetRefDir Condition="'@(_SdkNetRefCandidate)' != ''">%(_SdkNetRefCandidate.RootDir)%(_SdkNetRefCandidate.Directory)</_SdkNetRefDir>
      <_WinRTRuntimePath Condition="'$(_SdkNetRefDir)' != ''">$(_SdkNetRefDir)WinRT.Runtime.dll</_WinRTRuntimePath>
      <!-- The source generator is in the analyzers/dotnet/cs/ subdirectory of the NuGet package root -->
      <_SdkNetRefPkgRoot Condition="'$(_SdkNetRefDir)' != ''">$(_SdkNetRefDir)..\..\</_SdkNetRefPkgRoot>
      <_WinRTSourceGenPath Condition="'$(_SdkNetRefPkgRoot)' != ''">$(_SdkNetRefPkgRoot)analyzers\dotnet\cs\WinRT.SourceGenerator.dll</_WinRTSourceGenPath>
    </PropertyGroup>
    <ItemGroup Condition="Exists('$(_WinRTRuntimePath)')">
      <Reference Include="WinRT.Runtime">
        <HintPath>$(_WinRTRuntimePath)</HintPath>
        <Private>false</Private>
      </Reference>
    </ItemGroup>
    <ItemGroup Condition="Exists('$(_WinRTSourceGenPath)')">
      <Analyzer Include="$(_WinRTSourceGenPath)" />
    </ItemGroup>
    <Message Importance="high" Text="[_AddCsWinRTReferences] _SdkNetRefDir=$(_SdkNetRefDir)" />
    <Message Importance="high" Text="[_AddCsWinRTReferences] WinRT.Runtime.dll=$(_WinRTRuntimePath) Exists=$([System.IO.File]::Exists('$(_WinRTRuntimePath)'))" />
    <Message Importance="high" Text="[_AddCsWinRTReferences] WinRT.SourceGenerator.dll=$(_WinRTSourceGenPath) Exists=$([System.IO.File]::Exists('$(_WinRTSourceGenPath)'))" />
  </Target>

  <!--
    Set LocalAssembly before MarkupCompilePass2 so x:Bind type resolution works.
    WMC1509 "No LocalAssembly parameter given during MarkupCompilePass2" occurs when
    the intermediate assembly doesn't exist yet on first build.
  -->
  <Target Name="_SetLocalAssemblyForMarkupCompilePass2"
          BeforeTargets="MarkupCompilePass2"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences;CoreCompile">
    <PropertyGroup>
      <LocalAssembly Condition="'$(LocalAssembly)' == ''">$(IntermediateOutputPath)$(TargetName)$(TargetExt)</LocalAssembly>
      <XamlLocalAssembly Condition="'$(XamlLocalAssembly)' == ''">$(LocalAssembly)</XamlLocalAssembly>
    </PropertyGroup>
    <Message Importance="high" Text="[_SetLocalAssemblyForMarkupCompilePass2] LocalAssembly=$(LocalAssembly)" />
  </Target>
</Project>
