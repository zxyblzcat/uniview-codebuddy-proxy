<Project>
  <!--
    Remove ASP.NET Core reference assemblies before XamlCompiler runs.
    The net472 in-process CompileXaml task (used by MSBuild) can have issues
    with ASP.NET Core transitive refs from the Core project.
  -->
  <Target Name="_RemoveAspNetCoreRefsBeforeXamlCompiler"
          BeforeTargets="XamlMarkupCompilePass1;_XamlBuildExecTask;MarkupCompilePass1"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences">
    <ItemGroup>
      <_AspNetCoreRefs Include="@(ReferencePath)" Condition="$([System.String]::new('%(FullPath)').Contains('Microsoft.AspNetCore'))" />
      <ReferencePath Remove="@(_AspNetCoreRefs)" />
    </ItemGroup>
    <Message Importance="high" Text="[_RemoveAspNetCoreRefsBeforeXamlCompiler] Removed @(_AspNetCoreRefs->Count()) ASP.NET Core refs. Remaining ReferencePath: @(ReferencePath->Count())" />
  </Target>

  <!--
    Remove XamlPreCompile from PrepareResourcesDependsOn.
    XamlPreCompile is a target that runs an in-process C# compilation using the
    .NET Framework Roslyn csc.exe, which cannot resolve CsWinRT projected types
    (Microsoft.UI.Color, NavigationView, DispatcherQueue, etc.), causing CS0246.
    By removing it, all C# compilation is deferred to CoreCompile which uses the
    correct .NET 8 SDK Roslyn that supports WinRT type projection.
  -->
  <PropertyGroup>
    <PrepareResourcesDependsOn>
      ResolveKeySource;
      AddImplicitDefineConstant;
      MarkupCompilePass1;
      MarkupCompilePass2;
      $(PrepareResourcesDependsOn)
    </PrepareResourcesDependsOn>
  </PropertyGroup>

  <!--
    Set LocalAssembly before MarkupCompilePass2 so x:Bind type resolution works.
    WMC1509 "No LocalAssembly parameter given during MarkupCompilePass2" occurs when
    the intermediate assembly doesn't exist yet on first build. We point it to the
    CoreCompile output path which should exist by the time Pass2 runs (after Pass1
    generates code and CoreCompile produces the assembly).
  -->
  <Target Name="_SetLocalAssemblyForMarkupCompilePass2"
          BeforeTargets="MarkupCompilePass2"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences;CoreCompile">
    <PropertyGroup>
      <LocalAssembly Condition="'$(LocalAssembly)' == ''">$(IntermediateOutputPath)$(TargetName)$(TargetExt)</LocalAssembly>
      <XamlLocalAssembly Condition="'$(XamlLocalAssembly)' == ''">$(LocalAssembly)</XamlLocalAssembly>
    </PropertyGroup>
    <Message Importance="high" Text="[_SetLocalAssemblyForMarkupCompilePass2] LocalAssembly=$(LocalAssembly)" />
  </Target>
</Project>
