<Project>
  <!--
    Remove ASP.NET Core reference assemblies before XamlCompiler runs.
    The net472 in-process CompileXaml task (used by MSBuild) can have issues
    with ASP.NET Core transitive refs from the Core project.
  -->
  <Target Name="_RemoveAspNetCoreRefsBeforeXamlCompiler"
          BeforeTargets="XamlMarkupCompilePass1;_XamlBuildExecTask;MarkupCompilePass1"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences">
    <ItemGroup>
      <_AspNetCoreRefs Include="@(ReferencePath)" Condition="$([System.String]::new('%(FullPath)').Contains('Microsoft.AspNetCore'))" />
      <ReferencePath Remove="@(_AspNetCoreRefs)" />
    </ItemGroup>
    <Message Importance="high" Text="[_RemoveAspNetCoreRefsBeforeXamlCompiler] Removed @(_AspNetCoreRefs->Count()) ASP.NET Core refs. Remaining ReferencePath: @(ReferencePath->Count())" />
  </Target>

  <!--
    Remove XamlPreCompile from PrepareResourcesDependsOn.
    XamlPreCompile is a WPF/WinFX target inherited by the build pipeline.
    When it runs under MSBuild, it invokes the .NET Framework Roslyn csc.exe which
    cannot resolve WinRT projected types (Color, NavigationView, DispatcherQueue),
    causing CS0246 errors. Removing it lets the normal CoreCompile (which uses the
    correct .NET 8 Roslyn) handle all C# compilation.
  -->
  <PropertyGroup>
    <PrepareResourcesDependsOn>
      ResolveKeySource;
      AddImplicitDefineConstants;
      MarkupCompilePass1;
      MarkupCompilePass2;
      $(PrepareResourcesDependsOn)
    </PrepareResourcesDependsOn>
  </PropertyGroup>
</Project>
