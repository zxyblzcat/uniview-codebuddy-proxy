<Project>
  <!--
    The WinUI 3 XamlCompiler.exe (net472) cannot resolve CsWinRT projected types
    like Microsoft.UI.Color because the WinRT projection assemblies are not in its
    reference search path. This target finds all CsWinRT-generated projection DLLs
    and adds them to ReferencePath BEFORE XamlCompiler runs, so the compiler can
    resolve WinRT types.

    Additionally, ASP.NET Core transitive references from the Core project are removed
    because the net472 XamlCompiler cannot load .NET 6/8 reference assemblies.
  -->
  <Target Name="_AddCsWinRTRefsForXamlCompiler"
          BeforeTargets="XamlMarkupCompilePass1;_XamlBuildExecTask;MarkupCompilePass1"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences">
    <ItemGroup>
      <!-- Find CsWinRT projection assemblies in the NuGet packages -->
      <_CsWinRTProjections Include="@(ReferencePath)" Condition="
        $([System.String]::new('%(FileName)').StartsWith('Microsoft.UI')) OR
        $([System.String]::new('%(FileName)').StartsWith('Microsoft.Windows')) OR
        $([System.String]::new('%(FileName)').StartsWith('WinRT')) OR
        $([System.String]::new('%(FileName)').Equals('System.Runtime.InteropServices.WindowsRuntime'))" />

      <!-- Remove ASP.NET Core refs (net472 XamlCompiler can't load .NET 6/8 assemblies) -->
      <_AspNetCoreRefs Include="@(ReferencePath)" Condition="$([System.String]::new('%(FullPath)').Contains('Microsoft.AspNetCore'))" />
      <ReferencePath Remove="@(_AspNetCoreRefs)" />
    </ItemGroup>
    <Message Importance="high" Text="[_AddCsWinRTRefsForXamlCompiler] CsWinRT projections: @(_CsWinRTProjections->Count()), Removed ASP.NET Core refs: @(_AspNetCoreRefs->Count()), Remaining ReferencePath: @(ReferencePath->Count())" />
  </Target>

  <!--
    Set LocalAssembly before MarkupCompilePass2 so x:Bind type resolution works.
    WMC1509 "No LocalAssembly parameter given during MarkupCompilePass2" occurs when
    the intermediate assembly doesn't exist yet on first build.
  -->
  <Target Name="_SetLocalAssemblyForMarkupCompilePass2"
          BeforeTargets="MarkupCompilePass2"
          DependsOnTargets="ResolvePackageAssets;ResolveFrameworkReferences;ResolveAssemblyReferences;CoreCompile">
    <PropertyGroup>
      <LocalAssembly Condition="'$(LocalAssembly)' == ''">$(IntermediateOutputPath)$(TargetName)$(TargetExt)</LocalAssembly>
      <XamlLocalAssembly Condition="'$(XamlLocalAssembly)' == ''">$(LocalAssembly)</XamlLocalAssembly>
    </PropertyGroup>
    <Message Importance="high" Text="[_SetLocalAssemblyForMarkupCompilePass2] LocalAssembly=$(LocalAssembly)" />
  </Target>
</Project>
